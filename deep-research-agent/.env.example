# OpenAI API key for ChatOpenAI
OPENAI_API_KEY=your-openai-api-key

# Base URL for the OpenAI-compatible endpoint (leave default for OpenAI)
OPENAI_BASE_URL=https://api.openai.com/v1

# Model name (override to test other models available on your endpoint)
OPENAI_MODEL=gpt-4o

# Tavily API key for web search
TAVILY_API_KEY=your-tavily-api-key

# LangSmith key (optional) — enables tracing and the LangGraph Studio UI
LANGSMITH_API_KEY=your-langsmith-api-key
